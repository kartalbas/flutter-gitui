# Exclude all build artifacts and caches
build/
.dart_tool/
.packages

# Exclude Windows-specific files
windows/flutter/ephemeral/
# Host-generated plugin symlinks resolve to absolute Pub cache paths that do not
# exist inside the container; copying them in breaks CMake's add_subdirectory.
linux/flutter/ephemeral/
macos/Flutter/ephemeral/

# Exclude release artifacts (but keep source like updater)
release/artifacts/

# Exclude Git
.git/
.gitignore

# Exclude IDE
.vscode/
.idea/
*.iml

# Exclude temp files
*.log
*.tmp
.env
