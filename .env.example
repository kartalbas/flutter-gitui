# Optional: AI-assisted release changelog. Leave unset to fall back to a plain
# commit bullet list. Any chat-completions style endpoint works.
CHANGELOG_API_URL=
CHANGELOG_API_KEY=
CHANGELOG_API_MODEL=
# Optional: header carrying the key (default: "Authorization: Bearer <key>")
CHANGELOG_API_KEY_HEADER=
# Optional: extra headers, "Name: Value" separated by ";"
CHANGELOG_API_HEADERS=
SNAPCRAFT_STORE_CREDENTIALS=<snapcraft export-login --snaps=flutter-gitui --acls package_access,package_push,package_update,package_release snapcraft-creds.txt>
