*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# Executables
*.exe

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Windows build artifacts
windows/flutter/ephemeral/
release/updater/*.exe

# macOS build artifacts
macos/Flutter/ephemeral/

# Linux build artifacts
linux/flutter/ephemeral/

# Generated localization files
lib/generated/

# Build script artifacts
universal-build/.last-build-commit
universal-build/release/
.last-build-commit
.last-build-commit-*
# Secrets. Broad on purpose: a single missed pattern publishes a live
# credential, and .env.example below is the only file that must stay tracked.
.env
.env.*
!.env.example
*creds*
*credentials*
*secret*
*.pem
*.key
*.p12
*.pfx
*.obj

# Release build system - commit source, ignore artifacts
release/artifacts/**/*
!release/artifacts/.gitignore

build_windows.log
build_linux.log
I-copy-paste-the-console-output-to-here.txt
analyze_lints.ps1
hardcoded_colors.txt
icon_button_violations.txt
lint_results.txt
text_violations_current.txt
text_with_style_violations.txt
docs/UI-CONCEPT.md.backup

# Output of scripts/check_translations.dart - regenerate locally, never commit
scripts/translation_reports/
